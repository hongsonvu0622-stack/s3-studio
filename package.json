{
  "name": "s3-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Cross-Platform S3 Object Storage Desktop Studio",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "start": "npm run build && NODE_ENV=production electron .",
    "build": "vite build",
    "pack": "vite build && electron-builder --mac --win",
    "pack:mac": "vite build && electron-builder --mac",
    "pack:win": "vite build && electron-builder --win --ia32 --x64",
    "pack:win-ia32": "vite build && electron-builder --win --ia32",
    "pack:win-x64": "vite build && electron-builder --win --x64",
    "release": "bash scripts/publish-release.sh"
  },
  "build": {
    "appId": "com.s3studio.app",
    "productName": "S3 Studio",
    "releaseInfo": {
      "releaseNotesFile": "docs/RELEASE_NOTES.md"
    },
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hongsonvu0622-stack",
        "repo": "s3-studio",
        "releaseType": "release"
      }
    ],
    "icon": "public/logo.png",
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "public/logo.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/lib-storage": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
